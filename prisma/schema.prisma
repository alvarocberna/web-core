
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Proyecto {
  id                      String   @id @default(uuid())
  nombre_proyecto         String   @db.VarChar(200)
  descripcion             String   @db.VarChar(500)
  cliente                 String 
  fecha_inicio            DateTime
  activo                  Boolean    @default(true)
  //REL N:M 
  usuario                 Usuario[] @relation("fk_usu_pro")
  articulos               Articulos[] @relation("fk_arts_pro")
  actividad               Actividad[] @relation("fk_act_pro")
  equipo                  Equipo[] @relation("fk_equ_pro")
  servicios               Servicios[] @relation("fk_ser_pro")
  testimonios             Testimonios[] @relation("fk_tes_pro")
}

model Usuario {
  id                     String   @id @default(uuid())
  nombre                 String   @db.VarChar(50)
  apellido               String   @db.VarChar(50)
  email                  String   @unique @db.VarChar(100)
  fechaCreacion          DateTime
  password               String   
  hashedRt               String?
  rol                    String    
  img_url                String? @default("")
  img_alt                String? @default("") @db.VarChar(100)
  proyecto_id            String
  //REL M:N
  proyecto               Proyecto @relation(name: "fk_usu_pro", fields: [proyecto_id], references: [id], onDelete: Cascade)
  //REL N:M 
  actividad              Actividad[]        @relation("fk_act_usu")
  articulo               Articulo[]         @relation("fk_art_usu")
}

model Articulos {
  id                    String     @id @default(uuid())
  titulo                String     @default("Articulos") @db.VarChar(200)
  descripcion           String?    @db.VarChar(500)
  activo                Boolean    @default(true)
  aprobar               Boolean    @default(false)   
  habilitado            Boolean    @default(true)
  notificacion          Boolean    @default(false)
  proyecto_id           String
  //REL M:N
  proyecto              Proyecto @relation(name: "fk_arts_pro", fields: [proyecto_id], references: [id], onDelete: Cascade)
  //REL N:M
  articulo              Articulo[] @relation("fk_art_arts")   
}

model Articulo {
    id                   String              @id @default(uuid())
    nro_articulo         Int
    titulo               String              @db.VarChar(200)
    subtitulo            String?             @db.VarChar(500)
    autor                String
    fecha_publicacion    DateTime
    fecha_actualizacion  DateTime?
    status               String
    activo               Boolean
    slug                 String    
    image_url            String?
    image_alt            String?
    image_position       String?         
    articulos_id         String
    usuario_id           String
    //REL M:N
    articulos            Articulos @relation(name: "fk_art_arts", fields: [articulos_id], references: [id], onDelete: Cascade)
    usuario              Usuario @relation(name: "fk_art_usu", fields: [usuario_id], references: [id], onDelete: Cascade)
    //REL N:M
    sec_articulo         SecArticulo[]      @relation("fk_sec_art")
    actividad            Actividad[]        @relation("fk_act_art")
}

model SecArticulo {
    id                   String    @id @default(uuid())
    nro_seccion          Int
    titulo_sec           String?    @db.VarChar(200)
    contenido_sec        String?    
    image_url            String?
    image_alt            String?   @db.VarChar(100)
    image_position       String?
    articulo_id          String
    //REL M:N
    articulo             Articulo @relation(name: "fk_sec_art", fields: [articulo_id], references: [id], onDelete: Cascade)
}

model Equipo {
  id                     String     @id @default(uuid())
  titulo                 String     @default("Equipo")      @db.VarChar(200)
  descripcion            String?                            @db.VarChar(500)
  activo                 Boolean    @default(true)
  notificacion           Boolean    @default(false)
  habilitado             Boolean    @default(true)
  proyecto_id            String
  //REL M:N
  proyecto               Proyecto @relation(name: "fk_equ_pro", fields: [proyecto_id], references: [id], onDelete: Cascade)
  //REL N:M
  empleado               Empleado[] @relation("fk_emp_equ")
}

model Empleado {
  id                     String   @id @default(uuid())
  nombre_primero         String   @db.VarChar(50)
  nombre_segundo         String?  @db.VarChar(50)
  apellido_paterno       String   @db.VarChar(50)
  apellido_materno       String?  @db.VarChar(50)
  profesion              String?   @db.VarChar(100)
  especialidad           String?  @db.VarChar(200)
  descripcion            String?  @db.VarChar(500)
  orden                  Int?
  activo                 Boolean
  slug                   String   @default("")  
  img_url                String?
  img_alt                String?
  equipo_id              String
  //REL M:N
  equipo                 Equipo @relation(name: "fk_emp_equ", fields: [equipo_id], references: [id], onDelete: Cascade)
  //REL N:M
  sec_empleado          SecEmpleado[]      @relation("fk_sec_emp")
}

model SecEmpleado {
    id                   String    @id @default(uuid())
    nro_seccion          Int
    titulo_sec           String?    @db.VarChar(200)
    contenido_sec        String?    
    image_url            String?
    image_alt            String?   @db.VarChar(100)
    image_position       String?
    empleado_id          String
    //REL M:N
    empleado             Empleado @relation(name: "fk_sec_emp", fields: [empleado_id], references: [id], onDelete: Cascade)
}

model Servicios {
  id                    String     @id @default(uuid())
  titulo                String     @default("Servicios") @db.VarChar(200)
  descripcion           String?    @db.VarChar(500)
  icono                 String?    
  activo                Boolean    @default(true)
  notificacion          Boolean    @default(false)
  habilitado            Boolean    @default(true)
  proyecto_id           String
  //REL M:N
  proyecto              Proyecto @relation(name: "fk_ser_pro", fields: [proyecto_id], references: [id], onDelete: Cascade)
  //REL N:M
  servicio              Servicio[] @relation("fk_ser_ser")
}

model Servicio {
  id                    String   @id @default(uuid())
  nombre_servicio       String   @db.VarChar(200)
  descripcion           String?  @db.VarChar(500)
  valor                 Int?  
  nombre_promocion      String?  @db.VarChar(200)
  porcentaje_descuento  Int?
  destacado             Boolean
  icono                 String?
  orden                 Int?
  activo                Boolean
  slug                  String  @default("-")  
  img_url               String?
  img_alt               String?
  servicios_id          String
  //REL M:N
  servicios             Servicios @relation(name: "fk_ser_ser", fields: [servicios_id], references: [id], onDelete: Cascade)
  //REL N:M
  sec_servicio          SecServicio[]      @relation("fk_sec_ser")
}

model SecServicio {
    id                   String    @id @default(uuid())
    nro_seccion          Int
    titulo_sec           String?    @db.VarChar(200)
    contenido_sec        String?    
    image_url            String?
    image_alt            String?   @db.VarChar(100)
    image_position       String?
    servicio_id          String
    //REL M:N
    servicio             Servicio @relation(name: "fk_sec_ser", fields: [servicio_id], references: [id], onDelete: Cascade)
}

model Testimonios {
  id                    String      @id @default(uuid())
  titulo                String      @default("Testimonios") @db.VarChar(200)
  descripcion           String?     @db.VarChar(500)
  activo                Boolean     @default(true)
  aprobar               Boolean     @default(false)
  notificacion          Boolean     @default(false)
  habilitado            Boolean     @default(true)
  proyecto_id           String
  //REL M:N
  proyecto              Proyecto @relation(name: "fk_tes_pro", fields: [proyecto_id], references: [id], onDelete: Cascade)
  //REL N:M
  testimonio            Testimonio[] @relation("fk_tes_tes")
}

model Testimonio {
  id              String     @id @default(uuid())
  nombre          String     @db.VarChar(50)
  apellido        String     @db.VarChar(50)
  correo          String     @db.VarChar(100)
  descripcion     String     @db.VarChar(500)
  calificacion    Int?
  status          String
  fecha_creacion  DateTime
  testimonios_id  String
  //REL M:N
  testimonios     Testimonios @relation(name: "fk_tes_tes", fields: [testimonios_id], references: [id], onDelete: Cascade)
}

model Actividad {
    id                    String   @id @default(uuid())
    accion                String   
    titulo_articulo       String
    responsable           String
    fecha                 DateTime
    proyecto_id           String
    usuario_id            String?
    articulo_id           String?
    //REL M:N
    proyecto              Proyecto @relation(name: "fk_act_pro", fields: [proyecto_id], references: [id], onDelete: Cascade)
    usuario               Usuario? @relation(name: "fk_act_usu", fields: [usuario_id], references: [id], onDelete: SetNull)
    articulo              Articulo? @relation(name: "fk_act_art", fields: [articulo_id], references: [id], onDelete: SetNull)
}

model Click {
    id                    String    @id @default(uuid())
    fecha                 DateTime
    entidad_nombre        String
    entidad_id            String 
    proyecto_id           String

}
